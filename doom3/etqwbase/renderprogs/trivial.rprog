renderProgram trivialRGB {
	hwSkinningVersion trivialRGBSkinningMatrix trivialRGBHardSkinningMatrix

	program vertex reference trivial

	program fragment glsl { <%
		varying vec4 var_TexCoord;
		varying vec4 var_Color;

		void main ( void ) { 
			// ARB_precision_hint_fastest; 
			vec4 R0;
			R0.rgb = texture2D ( $map , var_TexCoord.xy ).rgb;
			R0.a = 1.0;
			gl_FragColor = R0 * var_Color;
		} 
	%> }
}

