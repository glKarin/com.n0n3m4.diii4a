}

renderProgram trivialAlpha {
	hwSkinningVersion trivialAlphaSkinningMatrix trivialAlphaHardSkinningMatrix

	program vertex reference trivial

	program fragment glsl { <%
		varying vec4 var_TexCoord;
		varying vec4 var_Color;

		void main ( void ) { 
			// ARB_precision_hint_fastest; 
			vec4 R0;
			R0.rgb = vec3 ( 1.0 );
			R0.a = texture2D ( $map , var_TexCoord.xy ).a;
			gl_FragColor = R0 * var_Color;
		} 
	%> }
}

